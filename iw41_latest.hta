/* ===== FOCO AZUL (HTA SAFE) ===== */
function focoOn(el){
    if(el){
        el.style.boxShadow = "0 0 6px rgba(0,170,255,0.6)";
    }
}

function focoOff(el){
    if(el){
        el.style.boxShadow = "none";
    }
}


/* ===== ERRO VERMELHO ===== */
function marcarErro(el){
    if(el) el.style.border="2px solid #ff3333";
}
function limparErro(el){
    if(el) el.style.border="1px solid #00ff66";
}


/* ================= MASCARAS ================= */
dataInicial.onkeyup = function () {

    // mant m apenas n meros
    var v = this.value.replace(/\D/g, "").substr(0, 8);

    // aplica m scara visual
    if (v.length >= 5)
        this.value = v.substr(0,2)+"/"+v.substr(2,2)+"/"+v.substr(4,4);
    else if (v.length >= 3)
        this.value = v.substr(0,2)+"/"+v.substr(2,2);
    else
        this.value = v;

    // valida agressivamente quando completo
    if (v.length === 8) {
        if (!isDataValida(v)) {
            this.value = "";      // ?? APAGA AUTOMATICAMENTE
            marcarErro(this);
        } else {
            limparErro(this);
        }
    }
};

dataInicial.onfocus = function(){
    focoOn(this);
};

horaInicial.onkeyup = function () {

    var v = this.value.replace(/\D/g, "").substr(0, 4);

    // m scara visual
    if (v.length >= 3)
        this.value = v.substr(0,2)+":"+v.substr(2,2);
    else
        this.value = v;

    // valida agressivamente quando completo
    if (v.length === 4) {
        if (!isHoraValida(v)) {
            this.value = "";      // ?? APAGA AUTOMATICAMENTE
            marcarErro(this);
        } else {
            limparErro(this);
        }
    }
};



horaInicial.onfocus = function(){
    focoOn(this);
};


dataInicial.onfocus=function(){focoOn(this);};

horaInicial.onfocus=function(){focoOn(this);};

ordemInicial.onfocus=function(){focoOn(this);};
ordemInicial.onblur=function(){focoOff(this);};

ordemFinal.onfocus=function(){focoOn(this);};
ordemFinal.onblur=function(){focoOff(this);};

totalTarefas.onfocus=function(){focoOn(this);};
totalTarefas.onblur=function(){focoOff(this);};

duracaoPadrao.onfocus=function(){focoOn(this);};
duracaoPadrao.onblur=function(){focoOff(this);};


/* ================= ORDENS ================= */
modoSeq.onclick=function(){
    areaSeq.className="";
    areaManual.className="hidden";
// ?? SALVA AP S ALTERAR
    salvarConfig();
};
modoManual.onclick=function(){
    areaSeq.className="hidden";
    areaManual.className="";
    listaManual.innerHTML="";
    adicionarLinhaOrdem();
// ?? SALVA AP S ALTERAR
    salvarConfig();
};

function validarOrdemManual(v){
    return /^\d{8}$/.test(v);
}

function adicionarLinhaOrdem(){
    var inputs=listaManual.getElementsByTagName("input");
    if(inputs.length>0){
        if(!validarOrdemManual(inputs[inputs.length-1].value)){
            alert("Digite exatamente 8 n meros antes de adicionar outra ordem.");
            return;
        }
    }
    var d=document.createElement("div");
    d.style.marginBottom="6px";

    var i=document.createElement("input");
    i.type="text";
    i.maxLength=8;
    i.onkeyup=function(){this.value=this.value.replace(/\D/g,"");};

    d.appendChild(i);
    listaManual.appendChild(d);
}

function obterOrdensManuais(){
    var arr=[];
    var inputs=listaManual.getElementsByTagName("input");
    for(var i=0;i<inputs.length;i++){
        if(!validarOrdemManual(inputs[i].value)){
            alert("Ordem invalida: "+inputs[i].value);
            return null;
        }
        arr.push(inputs[i].value);
    }
    return arr;
}


