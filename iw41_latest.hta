<html>
<head>
<title>Gerador Script SAP</title>
<meta charset="UTF-8">

<hta:application
    id="GeradorIW41"
    applicationname="Gerador IW41 v1.4"
    border="dialog"
    caption="yes"
    showintaskbar="yes"
    singleinstance="yes"
    sysmenu="yes"
    maximizebutton="yes"
    minimizebutton="yes"
    scroll="yes"
/>

<style>

/* ===== FIX GLOBAL HTA ===== */
* {
    box-sizing: border-box;
}

body{
    font-family: Consolas,"Courier New",monospace;
    background:#000;
    color:#00ff66;
    margin:20px;
    font-size:14px;
    letter-spacing: 0.3px;
    line-height: 1.5;
}

h1{
    font-size:20px;
    margin-bottom:15px;
}

fieldset{
    border:1px solid #00ff66;
    padding:10px;
    margin-bottom:15px;
}

legend{
    font-size:22px;
    letter-spacing:0.5px;
    text-transform:uppercase;
}

label{
    display:inline-block;
    width:180px;
    margin-bottom:6px;
    font-weight:600;
}

label.radio,
label.checkbox{
    display:inline-flex;
    align-items:center;
    gap:6px;
    font-size:15px;
}

input,
textarea,
select{
    background:#000;
    color:#fff;
    font-weight:bold;
    border:1px solid #00ff66;
    padding:4px;
    width:220px;
    font-size:14px;
}

textarea{
    width:320px;
    height:80px;
}

input[type="radio"],
input[type="checkbox"]{
    accent-color:#00ff66;
}

button{
    background:#000;
    color:#00ff66;
    border:1px solid #00ff66;
    padding:6px 14px;
    cursor:pointer;
}

button:hover{
    background:#00ff66;
    color:#000;
}

table{
    border-collapse:collapse;
    margin-top:8px;
}

table th,
table td{
    border:1px solid #00ff66;
    padding:4px 6px;
    vertical-align: middle;
}

.hidden{display:none;}

.contador{
    font-size:11px;
    text-align:right;
}

.contador.limite{
    color:#ff3333;
    font-weight:bold;
}

/* ===== FOCO / ERRO SEM ALTERAR ALTURA ===== */

.foco{
    border:1px solid #00aaff !important;
    box-shadow: inset 0 0 6px rgba(0,170,255,0.4);
}

.erro{
    border:1px solid #ff3333 !important;
    box-shadow: inset 0 0 6px rgba(255,51,51,0.4);
    background:#220000 !important;
}

input:focus,
select:focus,
textarea:focus{
    outline:none;
}

/* ================= TEMA SAP ================= */

.theme-sap{
    background:#f2f2f2;
    color:#000;
    font-family: "Segoe UI", Tahoma, Arial, sans-serif;
}

.theme-sap fieldset{
    border:1px solid #9e9e9e;
    background:#ffffff;
}

.theme-sap legend{
    color:#0a3d91;
}

.theme-sap input,
.theme-sap select,
.theme-sap textarea{
    background:#ffffff;
    color:#000;
    border:1px solid #7f7f7f;
}

.theme-sap button{
    background:#e6e6e6;
    color:#000;
    border:1px solid #7f7f7f;
}

.theme-sap button:hover{
    background:#d0d0d0;
}

.theme-sap table th{
    background:#e8edf3;
    color:#000;
}

.theme-sap table td{
    background:#ffffff;
}

/* ================= TEMA MODERN ================= */

.theme-modern{
    background:#0f172a;
    color:#e2e8f0;
    font-family:"Inter","Segoe UI",sans-serif;
}

/* ===== LEGEND ERP HEADER ===== */

.theme-modern fieldset{
    position: relative;
    padding: 35px 20px 20px 20px;
    margin-bottom: 20px;
    border: none !important;
    background: #1e293b;
    border-radius: 14px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.25);
}

.theme-modern legend{
    position: absolute;
    top: 8px;
    left: 20px;
    font-size: 18px;
    font-weight: 600;
    color: #3b82f6;
    letter-spacing: 0.5px;
}


.theme-modern input,
.theme-modern select,
.theme-modern textarea{
    background:#0f172a;
    border:1px solid #334155;
    border-radius:8px;
    color:#e2e8f0;
    padding:8px;
    transition:0.2s ease;
}

.theme-modern input:focus,
.theme-modern select:focus,
.theme-modern textarea:focus{
    border:1px solid #3b82f6;
    box-shadow: inset 0 0 6px rgba(59,130,246,0.4);
}

.theme-modern table{
    border-collapse: collapse;
}

.theme-modern table th,
.theme-modern table td{
    border: none !important;
}

.theme-modern table th,
.theme-modern table td{
    border:none;
    padding:6px 8px;
    vertical-align: middle;
}

.theme-modern table tr{
    border-bottom:1px solid #334155;
    height:42px;
}

.theme-modern table input{
    height:32px;
    padding:4px 6px;
}

/* ================= APP BETA ================= */

.app-beta{
    background:#0b1220;
    font-family:"Inter","Segoe UI",sans-serif;
}

.app-beta fieldset{
    border:none;
    background:#111827;
    border-radius:16px;
    padding:24px;
    margin-bottom:24px;
    box-shadow:0 10px 30px rgba(0,0,0,0.4);
}

.app-beta input,
.app-beta select,
.app-beta textarea{
    background:#0f172a;
    border:1px solid #334155;
    border-radius:10px;
    padding:10px;
    width:100%;
}

.app-beta table td,
.app-beta table th{
    vertical-align: middle;
}

#appSidebar{
    display:none;
}

/* ===== FIX MICRO SHIFT DEFINITIVO HTA ===== */

input,
select,
textarea{
    height: 32px;
    line-height: 32px;
    display: block;
}

textarea{
    height: 80px;
    line-height: 1.4;
}

table td{
    vertical-align: middle;
}

label{
    vertical-align: middle;
}

/* ===== PERSONALIZACAO FULL WIDTH CONTROLADA ===== */

#tabelaEletrica table{
    width: 80%;
}

#tabelaEletrica th:nth-child(1),
#tabelaEletrica td:nth-child(1){
    width: 70px;
    text-align:center;
}

#tabelaEletrica th:nth-child(2),
#tabelaEletrica td:nth-child(2){
    width: 100px;
    text-align:center;
}

#tabelaEletrica th:nth-child(3),
#tabelaEletrica td:nth-child(3){
    width: auto;
}

/* sobrescreve o width:220px somente na tabela */
#tabelaEletrica input{
    width: 100%;
}

/* ===== EXPANDIR INPUT TEXTO PERSONALIZADO ===== */

#tabelaEletrica td:nth-child(3) input{
    width: 100% !important;
    display: block;
}

#tabelaEletrica td:nth-child(3){
    padding-right: 10px;
}

#tabelaEletrica .contador{
    text-align: right;
    width: 100%;
}


/* ===== EXPANDIR INPUT TEXTO PERSONALIZADO ===== */

#tabelaEletrica td:nth-child(3) input{
    width: 100% !important;
    display: block;
}

#tabelaEletrica td:nth-child(3){
    padding-right: 10px;
}

#tabelaEletrica .contador{
    text-align: right;
    width: 100%;
}


/* ===== TABELA ERP INDUSTRIAL ===== */

.tabela-erp{
    width:100%;
    table-layout:fixed;
    border-collapse:collapse;
    font-size:13px;
}

.tabela-erp th{
    font-weight:600;
    text-align:left;
    padding:6px 8px;
    border-bottom:1px solid #00ff66;
}

.tabela-erp td{
    padding:4px 8px;
    vertical-align:middle;
    border-bottom:1px solid rgba(0,255,102,0.3);
}

/* COLUNAS */

.col-tarefa{
    width:60px;
    text-align:center;
}

.col-dur{
    width:80px;
    text-align:center;
}

.col-texto{
    width:auto;
}

/* INPUTS */

.tabela-erp input{
    width:100%;
    height:26px;
    padding:2px 6px;
    font-size:13px;
}

/* CONTADOR */

.tabela-erp .contador{
    font-size:10px;
    text-align:right;
    margin-top:2px;
    opacity:0.7;
}




</style>


</head>

<body class="theme-matrix" oncontextmenu="return false;">

<div id="appSidebar">
    <div class="sidebar-title">IW41</div>

    <div class="sidebar-item" onclick="scrollToSection(0)">Dados</div>
    <div class="sidebar-item" onclick="scrollToSection(1)">Ordens</div>
    <div class="sidebar-item" onclick="scrollToSection(2)">Tarefas</div>
    <div class="sidebar-item" onclick="scrollToSection(3)">Personaliza  o</div>
    <div class="sidebar-item" onclick="scrollToSection(4)">Resumo</div>
</div>

<div id="appContainer">

<button id="btnTema" onclick="alternarTema();" 
style="position:fixed; top:10px; right:10px; font-size:11px; padding:4px 8px; z-index:9999; opacity:0.7;">
Tema SAP
</button>

<button id="btnAppBeta"
        class="top-button"
        onclick="alternarAppBeta()"
        style="display:none;">
    APP BETA
</button>

<h1>Gerador de Script SAP</h1>

<!-- ================= DADOS GERAIS ================= -->
<fieldset>
<legend>1. Dados Gerais</legend>

<label>Data inicial:</label>
<input type="text" id="dataInicial" placeholder="DDMMAAAA" maxlength="10"><br>

<label>Hora inicial:</label>
<input type="text" id="horaInicial" placeholder="HHMM" maxlength="5"><br>

<label>Centro de trabalho:</label>
<select id="centroTrabalho">
    <option value="">-- selecione --</option>
    <option value="UTLME005">Carlos</option>
    <option value="UTLME008">Fernando</option>
    <option value="UTLEM002">Genuino</option>
    <option value="UTLRE007">Patrick</option>
</select>
</fieldset>

<!-- ================= ORDENS ================= -->
<fieldset>
<legend>2. Ordens</legend>

<label class="radio">
<input type="radio" name="modoOrdem" id="modoSeq" checked>
Sequencial
</label>

<label class="radio" style="margin-left:20px;">
<input type="radio" name="modoOrdem" id="modoManual">
Manual
</label><br><br>

<div id="areaSeq">
<label>Ordem inicial:</label>
<input type="text" id="ordemInicial" maxlength="8"><br>

<label>Ordem final:</label>
<input type="text" id="ordemFinal" maxlength="8">
</div>

<div id="areaManual" class="hidden">
<label>Ordens manuais:</label><br>
<div id="listaManual"></div>
<button type="button" onclick="adicionarLinhaOrdem()">+</button>
</div>
</fieldset>

<!-- ================= TAREFAS ================= -->
<fieldset>
<legend>3. Tarefas</legend>

<label class="radio">
<input type="radio" name="modoTarefa" id="modoTradicional" checked>
Modo Tradicional (Duração por tarefa)
</label>

<label class="radio" style="margin-left:20px;">
<input type="radio" name="modoTarefa" id="modoRandom">
Modo Random (Tempo total da ordem)
</label>

<br><br>

<label class="checkbox hidden" id="areaDebug">
<input type="checkbox" id="debugSAP">
Debug SAP (abrir IW41 e parar na T1)
</label>


<br><br>

<label>Total de tarefas:</label>
<input type="text" id="totalTarefas" maxlength="2"><br>

<label id="labelDuracao">Duração por tarefa (MIN):</label>
<input type="text" id="duracaoPadrao" maxlength="3">

</fieldset>

<!-- ================= PERSONALIZACAO ================= -->
<fieldset>
<legend>4. Personalizacao</legend>

<label class="checkbox">
<input type="checkbox" id="ordemEletrica">
Personalizar duração e texto por tarefa
</label>

<div id="areaEletrica" class="hidden">
<div id="tabelaEletrica"></div>
</div>
</fieldset>

<!-- ================= RESUMO ================= -->
<fieldset id="resumoFinal" class="hidden">
    <legend>Resumo do Apontamento</legend>
    <pre id="textoResumo" style="white-space:pre-wrap;"></pre>
</fieldset>


<div class="footer-bar">
    <button id="btnGerar" onclick="gerarVBS()">GERAR SCRIPT</button>

    <button id="btnExecutar"
            onclick="executarApontamento()"
            style="display:none;">
        EXECUTAR APONTAMENTO
    </button>

    <button id="btnResetRandom"
            style="display:none;"
            onclick="resetRandom()">
        RESET RANDOM
    </button>

    <button id="btnNovo"
            onclick="novoApontamento()"
            disabled>
        NOVO APONTAMENTO
    </button>
</div>

</div>




<script language="javascript">

<!-- ===== ASSINATURA DE INTEGRIDADE 26-02-2026 ===== -->
var __IW41_SIGNATURE__ = "IW41_BASE_V1_7_CONGELADA_OK";
var modoDev = false;
var btnAppBeta;
var btnTema;
var contadorCliqueDev = 0;
var VERSAO_APP = "1.7.11";
var URL_VERSAO = "https://iw41app.netlify.app/version.txt";
var URL_HTA    = "https://iw41app.netlify.app/iw41_latest.hta";

function scrollToSection(index){

    var sections = document.getElementsByTagName("fieldset");

    if(sections[index]){
        sections[index].scrollIntoView();
    }
}

function ativarModoDev(){

    var senha = prompt("Modo Desenvolvedor\nDigite a senha:");

    if(senha === "slim_crazy99"){

        modoDev = true;

        // Mostra Debug SAP
        document.getElementById("areaDebug").className = "checkbox";

        // Mostra bot o APP BETA
        btnAppBeta.style.display = "inline-block";

        alert("Modo Desenvolvedor ativado.");

    }else{
        alert("Senha incorreta.");
    }
}


function alternarAppBeta(){

    if(!modoDev){
        return;
    }

    var body = document.body;
    var atual = body.className;

    if(atual.indexOf("app-beta") !== -1){

        // Remove app-beta
        atual = atual.replace("app-beta", "");
        atual = atual.replace("  ", " "); // remove espa o duplo

        body.className = atual;

        btnAppBeta.innerText = "APP BETA";

    }else{

        if(atual === ""){
            body.className = "app-beta";
        }else{
            body.className = atual + " app-beta";
        }

        btnAppBeta.innerText = "SAIR APP";
    }
}

function desativarModoDev(){

    modoDev = false;

    var atual = document.body.className;

    if(atual.indexOf("app-beta") !== -1){
        atual = atual.replace("app-beta", "");
        atual = atual.replace("  ", " ");
        document.body.className = atual;
    }

    btnAppBeta.style.display = "none";
    btnAppBeta.innerText = "APP BETA";

    document.getElementById("areaDebug").className = "hidden";

    alert("Modo Desenvolvedor desativado.");
}

function alternarTema(){

    var atual = document.body.className;

    var novoTema = "";

    if(atual.indexOf("theme-matrix") !== -1){
        novoTema = "theme-sap";
        btnTema.innerText = "Tema Modern";
    }
    else if(atual.indexOf("theme-sap") !== -1){
        novoTema = "theme-modern";
        btnTema.innerText = "Tema Matrix";
    }
    else{
        novoTema = "theme-matrix";
        btnTema.innerText = "Tema SAP";
    }

    document.body.className = novoTema;

    salvarConfig();
}

function obterPastaHTA(){
    var caminho = obterCaminhoHTA();
    return caminho.substring(0, caminho.lastIndexOf("\\")+1);
}

function salvarConfig(){

    try{
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var pasta = obterPastaHTA();
        var caminhoINI = pasta + "IW41.config.ini";

        var arquivo = fso.CreateTextFile(caminhoINI, true);

        arquivo.WriteLine("TEMA=" + document.body.className);
        arquivo.WriteLine("CENTRO=" + centroTrabalho.value);
        arquivo.WriteLine("MODO=" + (modoManual.checked ? "MANUAL" : "SEQUENCIAL"));

        arquivo.Close();

    }catch(e){}
}


function carregarConfig(){

    try{
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var pasta = obterPastaHTA();
        var caminhoINI = pasta + "IW41.config.ini";

        if(!fso.FileExists(caminhoINI)){
            aplicarPadrao();
            return;
        }

        var arquivo = fso.OpenTextFile(caminhoINI, 1);
        var conteudo = arquivo.ReadAll();
        arquivo.Close();

        var linhas = conteudo.split("\n");

        for(var i=0;i<linhas.length;i++){

            var linha = linhas[i].replace("\r","");

            if(linha.indexOf("TEMA=") === 0){
                document.body.className = linha.replace("TEMA=","");
            }

            if(linha.indexOf("CENTRO=") === 0){
                centroTrabalho.value = linha.replace("CENTRO=","");
            }

            if(linha.indexOf("MODO=") === 0){
                var modo = linha.replace("MODO=","");

                if(modo === "MANUAL"){
                    modoManual.checked = true;
                    modoSeq.checked = false;
                    areaSeq.className = "hidden";
                    areaManual.className = "";
                }else{
                    modoSeq.checked = true;
                    modoManual.checked = false;
                    areaSeq.className = "";
                    areaManual.className = "hidden";
                }
            }
        }

    }catch(e){
        aplicarPadrao();
    }
}

function verificarAtualizacao(){

    try{

        var xhr = new ActiveXObject("WinHttp.WinHttpRequest.5.1");
        xhr.Open("GET", URL_VERSAO + "?t=" + new Date().getTime(), false);
        xhr.Send();

        if(xhr.Status !== 200){
            return;
        }

        var versaoOnline = xhr.ResponseText.replace(/\s/g,"");

        if(versaoOnline !== VERSAO_APP){

            var confirmar = confirm(
                "Nova versão disponível: v" + versaoOnline +
                "\nVersão atual: v" + VERSAO_APP +
                "\n\nDeseja atualizar agora?"
            );

            if(confirmar){
                baixarAtualizacao();
            }
        }

    }catch(e){
        // silencioso
    }
}

function obterCaminhoHTA(){
    var caminho = decodeURIComponent(location.pathname || "");

    if(location.href && location.href.indexOf("file:///") === 0){
        caminho = decodeURIComponent(location.href.replace("file:///", ""));
    }

    caminho = caminho.replace(/\//g,"\\");

    if(/^[\\\/][A-Za-z]:\\/.test(caminho)){
        caminho = caminho.substring(1);
    }

    return caminho;
}

function limparTemporariosAtualizacao(){
    try{
        var pasta = obterPastaHTA();
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var shell = new ActiveXObject("WScript.Shell");
        var arquivos = [
            pasta + "IW41_update.hta",
            pasta + "IW41_backup_pre_update.hta",
            pasta + "baixar_update_tmp.ps1",
            pasta + "atualizador_tmp.vbs"
        ];
        var i;

        for(i = 0; i < arquivos.length; i++){
            if(fso.FileExists(arquivos[i])){
                try{
                    fso.DeleteFile(arquivos[i], true);
                }catch(ex){
                    shell.Run('cmd /c ping 127.0.0.1 -n 4 > nul & del /f /q "' + arquivos[i] + '"', 0, false);
                }
            }
        }
    }catch(e){}
}

function baixarAtualizacao(){

    try{

        var pasta         = obterPastaHTA();
        var caminhoAtual  = obterCaminhoHTA();
        var caminhoNovo   = pasta + "IW41_update.hta";
        var caminhoVBS    = pasta + "atualizador_tmp.vbs";
        var caminhoPS1    = pasta + "baixar_update_tmp.ps1";
        var caminhoLog    = pasta + "update_log.txt";
        var caminhoBackup = pasta + "IW41_backup_pre_update.hta";
        var shell         = new ActiveXObject("WScript.Shell");
        var fso           = new ActiveXObject("Scripting.FileSystemObject");
        var log;

        if(fso.FileExists(caminhoLog)){
            fso.DeleteFile(caminhoLog, true);
        }

        log = fso.CreateTextFile(caminhoLog, true);
        log.WriteLine("===== INICIO UPDATE =====");
        log.WriteLine("DATA/HORA: " + new Date());
        log.WriteLine("caminhoAtual: " + caminhoAtual);
        log.WriteLine("caminhoNovo: " + caminhoNovo);
        log.WriteLine("caminhoVBS: " + caminhoVBS);
        log.WriteLine("caminhoPS1: " + caminhoPS1);
        log.WriteLine("caminhoBackup: " + caminhoBackup);
        log.Close();

        if(fso.FileExists(caminhoNovo)){
            fso.DeleteFile(caminhoNovo, true);
        }

        if(fso.FileExists(caminhoBackup)){
            fso.DeleteFile(caminhoBackup, true);
        }

        var ps1 = fso.CreateTextFile(caminhoPS1, true);
        ps1.WriteLine('$ProgressPreference = "SilentlyContinue"');
        ps1.WriteLine('try {');
        ps1.WriteLine('    Invoke-WebRequest -UseBasicParsing -Uri "' + URL_HTA + '" -OutFile "' + caminhoNovo + '" -ErrorAction Stop');
        ps1.WriteLine('    exit 0');
        ps1.WriteLine('} catch {');
        ps1.WriteLine('    exit 1');
        ps1.WriteLine('}');
        ps1.Close();

        log = fso.OpenTextFile(caminhoLog, 8, true);
        log.WriteLine("ps1 criado");
        log.Close();

        var comando = 'powershell.exe -NoProfile -ExecutionPolicy Bypass -File "' + caminhoPS1 + '"';

        log = fso.OpenTextFile(caminhoLog, 8, true);
        log.WriteLine("comando powershell:");
        log.WriteLine(comando);
        log.WriteLine("antes do shell.Run");
        log.Close();

        var rc = shell.Run(comando, 0, true);

        log = fso.OpenTextFile(caminhoLog, 8, true);
        log.WriteLine("depois do shell.Run");
        log.WriteLine("retorno powershell: " + rc);
        log.WriteLine("arquivo novo existe apos download: " + fso.FileExists(caminhoNovo));
        log.Close();

        if(fso.FileExists(caminhoPS1)){
            fso.DeleteFile(caminhoPS1, true);
        }

        if(rc !== 0 || !fso.FileExists(caminhoNovo)){
            alert("Falha ao baixar a nova versão.\nVeja update_log.txt");
            return;
        }

        var vbs = fso.CreateTextFile(caminhoVBS, true);
        vbs.WriteLine('On Error Resume Next');
        vbs.WriteLine('Set fso = CreateObject("Scripting.FileSystemObject")');
        vbs.WriteLine('Set sh = CreateObject("WScript.Shell")');
        vbs.WriteLine('logPath = "' + caminhoLog + '"');
        vbs.WriteLine('htaAtual = "' + caminhoAtual + '"');
        vbs.WriteLine('htaNovo = "' + caminhoNovo + '"');
        vbs.WriteLine('htaBackup = "' + caminhoBackup + '"');
        vbs.WriteLine('meuScript = WScript.ScriptFullName');
        vbs.WriteLine('Set log = fso.OpenTextFile(logPath, 8, True)');
        vbs.WriteLine('log.WriteLine "===== INICIO VBS ====="');
        vbs.WriteLine('log.Close');
        vbs.WriteLine('okTroca = False');
        vbs.WriteLine('For tentativa = 1 To 15');
        vbs.WriteLine('    Err.Clear');
        vbs.WriteLine('    If fso.FileExists(htaBackup) Then fso.DeleteFile htaBackup, True');
        vbs.WriteLine('    If fso.FileExists(htaAtual) Then fso.MoveFile htaAtual, htaBackup');
        vbs.WriteLine('    If Err.Number = 0 Then');
        vbs.WriteLine('        Err.Clear');
        vbs.WriteLine('        If fso.FileExists(htaNovo) Then fso.MoveFile htaNovo, htaAtual');
        vbs.WriteLine('        If Err.Number = 0 And fso.FileExists(htaAtual) Then');
        vbs.WriteLine('            okTroca = True');
        vbs.WriteLine('            Exit For');
        vbs.WriteLine('        End If');
        vbs.WriteLine('    End If');
        vbs.WriteLine('    Err.Clear');
        vbs.WriteLine('    If fso.FileExists(htaBackup) And Not fso.FileExists(htaAtual) Then');
        vbs.WriteLine('        fso.MoveFile htaBackup, htaAtual');
        vbs.WriteLine('    End If');
        vbs.WriteLine('    WScript.Sleep 1000');
        vbs.WriteLine('Next');
        vbs.WriteLine('Set log = fso.OpenTextFile(logPath, 8, True)');
        vbs.WriteLine('log.WriteLine "troca ok=" & okTroca & " err.number=" & Err.Number & " err.desc=" & Err.Description');
        vbs.WriteLine('log.Close');
        vbs.WriteLine('Err.Clear');
        vbs.WriteLine('If okTroca Then');
        vbs.WriteLine('    If fso.FileExists(htaBackup) Then fso.DeleteFile htaBackup, True');
        vbs.WriteLine('    CreateObject("WScript.Shell").Run Chr(34) & htaAtual & Chr(34), 1, False');
        vbs.WriteLine('Else');
        vbs.WriteLine('    CreateObject("WScript.Shell").Popup "Falha ao substituir o arquivo atual. Veja update_log.txt", 8, "Atualizacao IW41", 48');
        vbs.WriteLine('End If');
        vbs.WriteLine('Set log = fso.OpenTextFile(logPath, 8, True)');
        vbs.WriteLine('log.WriteLine "run hta err.number=" & Err.Number & " err.desc=" & Err.Description');
        vbs.WriteLine('sh.Run "cmd /c ping 127.0.0.1 -n 4 > nul & del /f /q """ & meuScript & """", 0, False');
        vbs.WriteLine('log.WriteLine "auto-delete agendado para o VBS"');
        vbs.WriteLine('log.WriteLine "===== FIM VBS ====="');
        vbs.WriteLine('log.Close');
        vbs.Close();

        log = fso.OpenTextFile(caminhoLog, 8, true);
        log.WriteLine("VBS criado");
        log.WriteLine("disparando wscript");
        log.Close();

        shell.Run('wscript.exe "' + caminhoVBS + '"', 0, false);

        log = fso.OpenTextFile(caminhoLog, 8, true);
        log.WriteLine("wscript disparado");
        log.WriteLine("fechando hta");
        log.Close();

        window.close();

    }catch(e){

        try{
            var fso2 = new ActiveXObject("Scripting.FileSystemObject");
            var log2 = fso2.OpenTextFile(obterPastaHTA() + "update_log.txt", 8, true);
            log2.WriteLine("ERRO NO HTA: " + e.message);
            log2.Close();
        }catch(ex){}

        alert("Falha na atualização automática.\nVeja update_log.txt");
    }
}


