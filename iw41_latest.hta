/* ================= TABELA ================= */
function atualizarContador(inp,id){
    var c=document.getElementById(id);
    c.innerText=inp.value.length+"/40";
    c.className=(inp.value.length>=40)?"contador limite":"contador";
}

function gerarTabela(){

    var t = parseInt(totalTarefas.value,10);
    tabelaEletrica.innerHTML = "";
    if(isNaN(t) || t < 1) return;

    var h = "<table class='tabela-erp'>";

    h += "<tr>";
    h += "<th class='col-tarefa'>Tarefa</th>";
    h += "<th class='col-dur'>Dur.</th>";
    h += "<th class='col-texto'>Texto da Atividade</th>";
    h += "</tr>";

    for(var i=1;i<=t;i++){

        h += "<tr>";

        h += "<td class='col-tarefa'>" + i + "</td>";

        h += "<td class='col-dur'>";
        h += "<input type='text' id='dur_"+i+"' maxlength='3'>";
        h += "</td>";

        h += "<td class='col-texto'>";
        h += "<input type='text' id='txt_"+i+"' maxlength='40' ";
        h += "onkeyup=\"atualizarContador(this,'cnt_"+i+"')\">";
        h += "<div id='cnt_"+i+"' class='contador'>0/40</div>";
        h += "</td>";

        h += "</tr>";
    }

    h += "</table>";

    tabelaEletrica.innerHTML = h;

    aplicarValidacaoDuracao();
}

ordemEletrica.onclick=function(){
    areaEletrica.className=this.checked?"":"hidden";
    if(this.checked)gerarTabela();
};


totalTarefas.onchange=function(){
    if(ordemEletrica.checked)gerarTabela();
};


function isDataValida(ddmmyyyy){
    if(ddmmyyyy.length !== 8) return false;

    var dd = parseInt(ddmmyyyy.substr(0,2),10);
    var mm = parseInt(ddmmyyyy.substr(2,2),10);
    var yy = parseInt(ddmmyyyy.substr(4,4),10);

    if(yy < 2026 || yy > 2100) return false;
    if(mm < 1 || mm > 12) return false;
    if(dd < 1) return false;

    var diasMes = [31,28,31,30,31,30,31,31,30,31,30,31];

    // ano bissexto
    if(mm === 2){
        if((yy % 4 === 0 && yy % 100 !== 0) || (yy % 400 === 0)){
            diasMes[1] = 29;
        }
    }

    if(dd > diasMes[mm-1]) return false;

    return true;
}

function isHoraValida(hhmm){
    if(hhmm.length !== 4) return false;

    var hh = parseInt(hhmm.substr(0,2),10);
    var mm = parseInt(hhmm.substr(2,2),10);

    if(hh < 0 || hh > 23) return false;
    if(mm < 0 || mm > 59) return false;

    return true;
}

function validar(){

    var ok = true;

   // ===== DATA =====
var dataLimpa = dataInicial.value.replace(/\D/g,"");
if(!isDataValida(dataLimpa)){
    marcarErro(dataInicial);
    ok = false;
} else {
    limparErro(dataInicial);
}

// ===== HORA =====
var horaLimpa = horaInicial.value.replace(/\D/g,"");
if(!isHoraValida(horaLimpa)){
    marcarErro(horaInicial);
    ok = false;
} else {
    limparErro(horaInicial);
}


    // ===== CENTRO =====
    if(centroTrabalho.value === ""){
        marcarErro(centroTrabalho);
        ok = false;
    } else {
        limparErro(centroTrabalho);
    }

    // ===== ORDENS =====
    if(modoSeq.checked){

        if(!/^\d{8}$/.test(ordemInicial.value)){
            marcarErro(ordemInicial);
            ok = false;
        } else {
            limparErro(ordemInicial);
        }

        if(!/^\d{8}$/.test(ordemFinal.value)){
            marcarErro(ordemFinal);
            ok = false;
        } else {
            limparErro(ordemFinal);
        }

    }

    if(modoManual.checked){
        if(!obterOrdensManuais()){
            ok = false;
        }
    }

    // ===== TAREFAS =====
    var t = parseInt(totalTarefas.value,10);
    if(isNaN(t) || t < 1 || t > 99){
        marcarErro(totalTarefas);
        ok = false;
    } else {
        limparErro(totalTarefas);
    }

    var d = parseInt(duracaoPadrao.value,10);
    if(isNaN(d) || d < 1 || d > 660){
        marcarErro(duracaoPadrao);
        ok = false;
    } else {
        limparErro(duracaoPadrao);
    }

    return ok;
}

function aplicarValidacaoDuracao(){
    for(var i=1;i<=99;i++){
        var d = document.getElementById("dur_"+i);
        if(!d) continue;

        d.onkeyup = function(){
            this.value = this.value.replace(/\D/g,"");
            if(this.value !== ""){
                var n = parseInt(this.value,10);
                if(n > 660) this.value = "660";
                if(n === 0) this.value = "";
            }
        };

        d.onblur = function(){
            if(this.value !== ""){
                var n = parseInt(this.value,10);
                if(isNaN(n) || n < 1 || n > 660){
                    marcarErro(this);
                } else {
                    limparErro(this);
                }
            } else {
                limparErro(this); // vazio = usa padr o
            }
        };
    }
}

/* ===== VALIDA  O TOTAL DE TAREFAS (1 99) ===== */
totalTarefas.onkeyup = function(){
    this.value = this.value.replace(/\D/g,"");
    if(this.value !== ""){
        var n = parseInt(this.value,10);
        if(n > 99) this.value = "99";
        if(n === 0) this.value = "";
    }
};

totalTarefas.onblur = function(){
    if(this.value === ""){
        marcarErro(this);
        return;
    }
    var n = parseInt(this.value,10);
    if(isNaN(n) || n < 1 || n > 99){
        marcarErro(this);
    } else {
        limparErro(this);
    }
};

/* ===== VALIDA  O DURA  O PADR O (1 660) ===== */
duracaoPadrao.onkeyup = function(){
    this.value = this.value.replace(/\D/g,"");
    if(this.value !== ""){
        var n = parseInt(this.value,10);
        if(n > 660) this.value = "660";
        if(n === 0) this.value = "";
    }
};

duracaoPadrao.onblur = function(){
    if(this.value === ""){
        marcarErro(this);
        return;
    }
    var n = parseInt(this.value,10);
    if(isNaN(n) || n < 1 || n > 660){
        marcarErro(this);
    } else {
        limparErro(this);
    }
};

/* ===== ORDENS SEQUENCIAIS   SOMENTE N MEROS (8 D GITOS) ===== */
ordemInicial.onkeyup = function(){
    this.value = this.value.replace(/\D/g,"").substr(0,8);
};

ordemFinal.onkeyup = function(){
    this.value = this.value.replace(/\D/g,"").substr(0,8);
};

ordemInicial.onblur = function(){
    if(modoSeq.checked){
        if(this.value.length !== 8){
            marcarErro(this);
        } else {
            limparErro(this);
        }
    }
};

ordemFinal.onblur = function(){
    if(modoSeq.checked){
        if(this.value.length !== 8){
            marcarErro(this);
        } else {
            limparErro(this);
        }
    }
};


/* ===== MODO SOMENTE LEITURA (HTA COMPAT VEL) ===== */
function setSomenteLeitura(ativo){

    var inputs = document.getElementsByTagName("input");
    var selects = document.getElementsByTagName("select");
    var textareas = document.getElementsByTagName("textarea");
    var buttons = document.getElementsByTagName("button");

    // INPUTS
    for(var i=0;i<inputs.length;i++){
        if(
            inputs[i].type !== "button" &&
            inputs[i].type !== "checkbox" &&
            inputs[i].type !== "radio"
        ){
            inputs[i].readOnly = ativo;
            inputs[i].style.opacity = ativo ? "0.7" : "1";
        }
    }

    // SELECTS
    for(var j=0;j<selects.length;j++){
        selects[j].disabled = ativo;
        selects[j].style.opacity = ativo ? "0.7" : "1";
    }

    // TEXTAREAS
    for(var k=0;k<textareas.length;k++){
        textareas[k].readOnly = ativo;
        textareas[k].style.opacity = ativo ? "0.7" : "1";
    }

    // RADIOS / CHECKBOXES
    modoSeq.disabled        = ativo;
    modoManual.disabled    = ativo;
    ordemEletrica.disabled = ativo;

    // BOTOES
    for(var b=0;b<buttons.length;b++){
        if(buttons[b].innerText !== "GERAR SCRIPT" &&
           buttons[b].innerText !== "NOVO APONTAMENTO"){
            buttons[b].disabled = ativo;
            buttons[b].style.opacity = ativo ? "0.7" : "1";
        }
    }
}


function montarResumo(){

    var resumo = document.getElementById("resumoFinal");
    var texto  = document.getElementById("textoResumo");

    if(!resumo || !texto){
        return; // evita erro em HTA
    }

    var r = "";
    r += "Data inicial: " + dataInicial.value + "\n";
    r += "Hora inicial: " + horaInicial.value + "\n";
    r += "Centro: " + centroTrabalho.value + "\n\n";

    if(modoSeq.checked){
        r += "Modo: Sequencial\n";
        r += "Ordem inicial: " + ordemInicial.value + "\n";
        r += "Ordem final: " + ordemFinal.value + "\n";
    } else {
        r += "Modo: Manual\n";
        var arr = obterOrdensManuais();
        if(arr && arr.length){
            r += "Ordens: " + arr.join(", ") + "\n";
        }
    }

    r += "\nTotal de tarefas: " + totalTarefas.value + "\n";
    r += "Duracao padrao: " + duracaoPadrao.value + " min\n";
    r += "Personalizacao: " + (ordemEletrica.checked ? "SIM" : "NAO") + "\n";


// ===== CALCULO HORA FINAL MULTI-ORDEM (v1.7.7) =====

var total = parseInt(totalTarefas.value,10);
var durPadrao = parseInt(duracaoPadrao.value,10);
var hora  = horaInicial.value.replace(/\D/g,"");

if(!isNaN(total) && !isNaN(durPadrao) && hora.length === 4){

    var minutosPorOrdem = 0;

    // ===== CALCULA TEMPO DE UMA ORDEM =====
    if(ordemEletrica.checked){

        for(var i=1;i<=total;i++){

            var campo = document.getElementById("dur_"+i);

            if(campo && campo.value !== ""){
                minutosPorOrdem += parseInt(campo.value,10);
            }else{
                minutosPorOrdem += durPadrao;
            }
        }

    }else{

        minutosPorOrdem = total * durPadrao;

    }

    // ===== CALCULA QUANTIDADE DE ORDENS =====
    var quantidadeOrdens = 1;

    if(modoSeq.checked){

        var ini = parseInt(ordemInicial.value,10);
        var fim = parseInt(ordemFinal.value,10);

        if(!isNaN(ini) && !isNaN(fim) && fim >= ini){
            quantidadeOrdens = (fim - ini) + 1;
        }

    }

    if(modoManual.checked){

        var arr = obterOrdensManuais();
        if(arr && arr.length){
            quantidadeOrdens = arr.length;
        }

    }

// ===== TEMPO TOTAL GERAL =====
var minutosTotais = minutosPorOrdem * quantidadeOrdens;

var hh = parseInt(hora.substr(0,2),10);
var mm = parseInt(hora.substr(2,2),10);

var dataBase = new Date(2024,0,1,hh,mm,0);

// ===== DETALHAMENTO POR ORDEM =====
r += "\nDetalhamento por ordem:\n";
r += "--------------------------------\n";

var horaCorrente = new Date(dataBase);

for(var o=1; o<=quantidadeOrdens; o++){

    var inicioOrdem = new Date(horaCorrente);

    horaCorrente.setMinutes(horaCorrente.getMinutes() + minutosPorOrdem);

    var fimOrdem = new Date(horaCorrente);

    var horaIniFmt =
        ("0"+inicioOrdem.getHours()).slice(-2) + ":" +
        ("0"+inicioOrdem.getMinutes()).slice(-2);

    var horaFimFmt =
        ("0"+fimOrdem.getHours()).slice(-2) + ":" +
        ("0"+fimOrdem.getMinutes()).slice(-2);

    r += "Ordem " + o + " → " + horaIniFmt + " às " + horaFimFmt + "\n";
}

// ===== HORA FINAL GERAL =====
var horaFinalGeral =
    ("0"+horaCorrente.getHours()).slice(-2) + ":" +
    ("0"+horaCorrente.getMinutes()).slice(-2);

r += "--------------------------------\n";
r += "Ordens processadas: " + quantidadeOrdens + "\n";
r += "Tempo por ordem: " + minutosPorOrdem + " min\n";
r += "Tempo Total Geral: " + minutosTotais + " min\n";
r += "Hora Final Geral: " + horaFinalGeral + "\n";
}
    texto.innerText = r;
    resumo.className = ""; // remove hidden
    resumo.style.display = "block";
}

/* ================= GERAR VBS ================= */
function gerarVBS(){
    
if(modoRandom.checked){
        executarRandomOficial();
        return;
    }

    if(!validar()) return;

    montarResumo();


    var data=dataInicial.value.replace(/\D/g,"");
    var hora=horaInicial.value.replace(/\D/g,"");
    var centro=centroTrabalho.value;
    var total=parseInt(totalTarefas.value,10);
    var dur=parseInt(duracaoPadrao.value,10);
    var eletrica=ordemEletrica.checked;

    var caminho=decodeURIComponent(location.pathname).replace(/\//g,"\\");
    var pasta=caminho.substring(0,caminho.lastIndexOf("\\")+1);

    var vbs="";
    var log="";

    /* ===== SETUP ===== */
    vbs+="' ============================================================\n";
    vbs+="' ========================== SETUP ===========================\n";
    vbs+="' ============================================================\n\n";

    if(modoManual.checked){
        var arr=obterOrdensManuais();
        vbs+="Dim ORDEM_INICIAL, ORDEM_FINAL\n";
        vbs+="ORDEM_INICIAL = -1\nORDEM_FINAL = 0\n\n";
        vbs+="Dim ORDENS_MANUAIS\nORDENS_MANUAIS = Array(";
        for(var i=0;i<arr.length;i++){
            vbs+="\""+arr[i]+"\""+(i<arr.length-1?",":"");
        }
        vbs+=")\n\n";
        log+="ORDENS_MANUAIS="+arr.join(",")+"\n";
    }else{
        vbs+="Dim ORDEM_INICIAL, ORDEM_FINAL\n";
        vbs+="ORDEM_INICIAL = "+ordemInicial.value+"\n";
        vbs+="ORDEM_FINAL   = "+ordemFinal.value+"\n\n";
        vbs+="Dim ORDENS_MANUAIS\nORDENS_MANUAIS = Array()\n\n";
        log+="ORDEM_INICIAL="+ordemInicial.value+"\n";
        log+="ORDEM_FINAL="+ordemFinal.value+"\n";
    }

    vbs+="Dim DATA_INICIAL, HORA_INICIAL, CENTRO_TRAB, TOTAL_TAREFAS, DURACAO_TAREFA\n";
    vbs+="DATA_INICIAL=\""+data+"\"\n";
    vbs+="HORA_INICIAL=\""+hora+"\"\n";
    vbs+="CENTRO_TRAB=\""+centro+"\"\n";
    vbs+="TOTAL_TAREFAS="+total+"\n";
    vbs+="DURACAO_TAREFA="+dur+"\n\n";

    vbs+="Dim ORDEM_ELETRICA, TEXTO_PADRAO\n";
    vbs+="ORDEM_ELETRICA="+(eletrica?"True":"False")+"\n";
    vbs+="TEXTO_PADRAO=\"OK\"\n\n";

    vbs+="Dim MAPA_TEXTO_ELETRICO:Set MAPA_TEXTO_ELETRICO=CreateObject(\"Scripting.Dictionary\")\n";
    vbs+="Dim MAPA_DURACAO_TAREFA:Set MAPA_DURACAO_TAREFA=CreateObject(\"Scripting.Dictionary\")\n\n";

    if(eletrica){
        for(var i=1;i<=total;i++){
            var t=document.getElementById("txt_"+i);
            var d=document.getElementById("dur_"+i);
            if (t && t.value.replace(/^\s+|\s+$/g,"") !== ""){
                vbs+="MAPA_TEXTO_ELETRICO.Add "+i+", \""+t.value+"\"\n";
                log+="TEXTO_"+i+"="+t.value+"\n";
            }
            if(d&&d.value!==""){
                vbs+="MAPA_DURACAO_TAREFA.Add "+i+", "+d.value+"\n";
                log+="DURACAO_"+i+"="+d.value+"\n";
            }
        }
        vbs+="\n";
    }

/* ===== SCRIPT SAP 2.5 ===== */
if(debugSAP && debugSAP.checked){
    vbs += gerarScriptDebugSAP();
}else{
    vbs += document.getElementById("SCRIPT_SAP_25").value;
}


var fso = new ActiveXObject("Scripting.FileSystemObject");
var caminhoVBS = pasta + "Apontamento_IW41.vbs";
var caminhoINI = pasta + "Apontamento_IW41.ini";

var f = fso.CreateTextFile(caminhoVBS, true);
f.Write(vbs);
f.Close();

var l = fso.CreateTextFile(caminhoINI, true);
l.Write(log);
l.Close();

/* ===== EXECUTA O VBS AUTOMATICAMENTE ===== */
var shell = new ActiveXObject("WScript.Shell");

/*
  0 = janela oculta
  false = N O esperar terminar (SAP assume a frente)
*/
shell.Run('"' + caminhoVBS + '"', 0, false);

alert("Script executado no SAP.\nAguarde o processamento.");


    // trava edicao e libera novo apontamento
    setSomenteLeitura(true);
    btnGerar.disabled = true;
    btnNovo.disabled  = false;

}

function novoApontamento(){

    // libera edição
    setSomenteLeitura(false);

    // limpa campos operacionais
    dataInicial.value = "";
    horaInicial.value = "";

    ordemInicial.value = "";
    ordemFinal.value = "";

    totalTarefas.value = "";
    duracaoPadrao.value = "";

    ordemEletrica.checked = false;
    areaEletrica.className = "hidden";

    listaManual.innerHTML = "";
    tabelaEletrica.innerHTML = "";

    // ===== DESBLOQUEIA CAMPOS DURACAO =====
    for(var z=1; z<=99; z++){
        var campoUnlock = document.getElementById("dur_"+z);
        if(campoUnlock){
            campoUnlock.readOnly = false;
            campoUnlock.style.background = "";
            campoUnlock.style.color = "";
        }
    }

    // ===== ESCONDE RESUMO =====
    var resumo = document.getElementById("resumoFinal");
    var texto  = document.getElementById("textoResumo");

    if(resumo){
        resumo.className = "hidden";
        resumo.style.display = "none";
    }

    if(texto){
        texto.innerText = "";
    }

    // ===== RESTAURA CONFIGURACOES SALVAS =====
    limparTemporariosAtualizacao();
    carregarConfig();

    // ===== FORCA MODO TRADICIONAL COMO PADRAO VISUAL =====
    modoTradicional.checked = true;
    modoRandom.checked = false;
    labelDuracao.innerText = "Duração por tarefa (MIN):";
    btnGerar.innerText = "GERAR SCRIPT";

    // ===== RESTAURA BOTOES =====
    btnGerar.disabled = false;
    btnNovo.disabled  = true;

    btnGerar.style.display = "inline-block";
    btnResetRandom.style.display = "none";

    if(typeof btnExecutar !== "undefined"){
        btnExecutar.style.display = "none";
    }

    window.scrollTo(0,0);
}

function executarDebugRandom(){

    var total = parseInt(document.getElementById("totalTarefas").value,10);
    var tempoTotal = parseInt(document.getElementById("duracaoPadrao").value,10);

    if(isNaN(total) || total < 1){
        alert("Informe o total de tarefas.");
        return;
    }

    if(isNaN(tempoTotal) || tempoTotal < 1){
        alert("Informe o tempo total (usando campo duração padrão).");
        return;
    }

    var tempos = [];
    var somaFixos = 0;
    var tarefasVazias = [];

    // Captura dura  es personalizadas
    for(var i=1;i<=total;i++){

        var campo = document.getElementById("dur_"+i);

        if(campo && campo.value !== ""){
            var val = parseInt(campo.value,10);
            tempos[i] = val;
            somaFixos += val;
        }else{
            tempos[i] = 0;
            tarefasVazias.push(i);
        }
    }

    var restante = tempoTotal - somaFixos;

    if(restante < 0){
        alert("Tempo personalizado excede o tempo total.");
        return;
    }

    // Distribui  o aleat ria controlada
    while(restante > 0 && tarefasVazias.length > 0){

        for(var j=0;j<tarefasVazias.length;j++){

            if(restante <= 0) break;

            var tarefaIndex = tarefasVazias[j];

            var add = Math.floor(Math.random() * 3) + 1; // 1 a 3 min

            if(add > restante) add = restante;

            tempos[tarefaIndex] += add;
            restante -= add;
        }
    }

    // Garantir m nimo 1 minuto se sobrar tarefa zerada
    for(var k=1;k<=total;k++){
        if(tempos[k] === 0){
            tempos[k] = 1;
        }
    }

    // Monta resumo
    var r = "===== DEBUG RANDOM =====\n\n";

    var somaFinal = 0;

    for(var x=1;x<=total;x++){
        r += "Tarefa " + x + " : " + tempos[x] + " min\n";
        somaFinal += tempos[x];
    }


// ===== PREENCHE TABELA PERSONALIZA  O =====
for(var p=1;p<=total;p++){
    var campoDur = document.getElementById("dur_"+p);
    if(campoDur){
        campoDur.value = tempos[p];
    }
}

    r += "\nTempo Total: " + somaFinal + " min";

// ===== CALCULA HORA FINAL =====
var horaIniStr = document.getElementById("horaInicial").value;

if(horaIniStr && horaIniStr.indexOf(":") > -1){

    var partes = horaIniStr.split(":");
    var h = parseInt(partes[0],10);
    var m = parseInt(partes[1],10);

    var totalMin = (h * 60) + m + somaFinal;

    var horaFinalH = Math.floor(totalMin / 60) % 24;
    var horaFinalM = totalMin % 60;

    var horaFinalFormatada =
        (horaFinalH < 10 ? "0"+horaFinalH : horaFinalH) + ":" +
        (horaFinalM < 10 ? "0"+horaFinalM : horaFinalM);

    r += "\nHora Inicial: " + horaIniStr;
    r += "\nHora Final: " + horaFinalFormatada;
}

    textoResumo.innerText = r;

    var resumo = document.getElementById("resumoFinal");
    resumo.className = "";
    resumo.style.display = "block";
}


function executarRandomOficial(){

    if(!validar()) return;

    var total = parseInt(totalTarefas.value,10);
    var tempoTotal = parseInt(duracaoPadrao.value,10);

    if(isNaN(total) || total < 1){
        alert("Informe o total de tarefas.");
        return;
    }

    if(isNaN(tempoTotal) || tempoTotal < 1){
        alert("Informe o tempo total da ordem.");
        return;
    }

    // Ativa personaliza  o apenas se n o estiver ativa
    if(!ordemEletrica.checked){
        ordemEletrica.checked = true;
        areaEletrica.className = "";
        gerarTabela();
    }

    var tempos = [];
    var somaFixos = 0;
    var tarefasVazias = [];

    // Captura valores existentes
    for(var i=1;i<=total;i++){

        var campo = document.getElementById("dur_"+i);

        if(campo && campo.value !== ""){
            var val = parseInt(campo.value,10);
            if(!isNaN(val)){
                tempos[i] = val;
                somaFixos += val;
            }else{
                tempos[i] = 0;
                tarefasVazias.push(i);
            }
        }else{
            tempos[i] = 0;
            tarefasVazias.push(i);
        }
    }

    // Se fixos j  ultrapassam
    if(somaFixos > tempoTotal){
        alert("A soma das tarefas preenchidas excede o tempo total.");
        return;
    }

    var restante = tempoTotal - somaFixos;
    var qtdVazias = tarefasVazias.length;

    // BLOQUEIO: tempo insuficiente
    if(restante < qtdVazias){
        var minimo = somaFixos + qtdVazias;
        alert("Tempo total insuficiente.\nM nimo necess rio: " + minimo + " minutos.");
        return;
    }

    // ===== DISTRIBUI  O PROPORCIONAL =====
    if(qtdVazias > 0){

        var base = Math.floor(restante / qtdVazias);
        var resto = restante % qtdVazias;

        // Aplica base
        for(var j=0;j<qtdVazias;j++){
            var idx = tarefasVazias[j];
            tempos[idx] = base;
        }

        // Embaralha tarefas vazias (shuffle Fisher-Yates)
        for(var k=qtdVazias-1;k>0;k--){
            var r = Math.floor(Math.random() * (k+1));
            var temp = tarefasVazias[k];
            tarefasVazias[k] = tarefasVazias[r];
            tarefasVazias[r] = temp;
        }

        // Distribui resto aleatoriamente
        for(var x=0;x<resto;x++){
            var tarefaIndex = tarefasVazias[x];
            tempos[tarefaIndex] += 1;
        }
    }

    // Preenche tabela
    for(var y=1;y<=total;y++){
        var campoFinal = document.getElementById("dur_"+y);
        if(campoFinal){
            campoFinal.value = tempos[y];
        }
    }

// ===== BLOQUEIA EDI  O AP S RANDOM =====
for(var z=1; z<=total; z++){
    var campoLock = document.getElementById("dur_"+z);
    if(campoLock){
        campoLock.readOnly = true;
        campoLock.style.background = "#222";
        campoLock.style.color = "#00ff66";
    }
}

// Atualiza resumo
montarResumo();

// Esconde bot o GERAR RANDOM
btnGerar.style.display = "none";

// Exibe bot o executar
if(typeof btnExecutar !== "undefined"){
    btnExecutar.style.display = "inline-block";
}

// Exibe bot o reset
btnResetRandom.style.display = "inline-block";
}


function resetRandom(){

    var total = parseInt(totalTarefas.value,10);

    for(var i=1;i<=total;i++){
        var campo = document.getElementById("dur_"+i);
        if(campo){
            campo.readOnly = false;
            campo.value = "";
            campo.style.background = "";
            campo.style.color = "";
        }
    }

    btnResetRandom.style.display = "none";
    if(typeof btnExecutar !== "undefined"){
        btnExecutar.style.display = "none";
    }

// Mostra novamente GERAR RANDOM
btnGerar.style.display = "inline-block";

}

function executarApontamento(){

    // Valida novamente antes de executar
    if(!validar()) return;

    // Esconde bot o executar para evitar duplo clique
    btnExecutar.style.display = "none";
    btnResetRandom.style.display = "none";

    // Chama fluxo normal de gera  o VBS
    modoRandom.checked = false; // for a entrar no fluxo tradicional
    gerarVBS();

}


function atualizarBotaoPrincipal(){

    if(modoRandom.checked){
        btnGerar.innerText = "GERAR RANDOM";
    }else{
        btnGerar.innerText = "GERAR SCRIPT";
    }
}

function aplicarPadrao(){

    document.body.className = "theme-matrix";

    centroTrabalho.value = "";

    modoSeq.checked = true;
    modoManual.checked = false;

    areaSeq.className = "";
    areaManual.className = "hidden";
}

window.onload = function(){
    
    btnAppBeta = document.getElementById("btnAppBeta");
    btnTema    = document.getElementById("btnTema");
    btnAppBeta.style.display = "none";

    limparTemporariosAtualizacao();
    carregarConfig();
    document.title = "Gerador Script SAP - IW41 v" + VERSAO_APP;

    // ===== MODO DEV 5 CLIQUES NO TITULO =====
var contadorClique = 0;
var timeoutClique;

var titulo = document.getElementsByTagName("h1")[0];

if(titulo){
    titulo.onclick = function(){

        contadorClique++;

        clearTimeout(timeoutClique);

        timeoutClique = setTimeout(function(){
            contadorClique = 0;
        }, 2000);

        if(contadorClique >= 5){

            contadorClique = 0;

            if(!modoDev){
                ativarModoDev();
            }else{
                desativarModoDev();
            }
        }
    };
}
verificarAtualizacao();
};
</script>

<textarea id="SCRIPT_SAP_25" style="display:none;">




' ============================================================
' ======================= SAP CONEXAO 01-03-26 ========================
' ============================================================

If Not IsObject(application) Then
   Set SapGuiAuto  = GetObject("SAPGUI")
   Set application = SapGuiAuto.GetScriptingEngine
End If
If Not IsObject(connection) Then
   Set connection = application.Children(0)
End If
If Not IsObject(session) Then
   Set session = connection.Children(0)
End If

session.findById("wnd[0]").maximize


' ============================================================
' ===== FUNCAO TEMPO + DATA (SEGURA / SEM LOCALE) ============
' ============================================================

Function SomaMinutosComData(ByRef dataTmp, horaAtual, minutos)
    Dim d, h, m, dt

    d = DateSerial(CInt(Right(dataTmp,4)), CInt(Mid(dataTmp,3,2)), CInt(Left(dataTmp,2)))
    h = CInt(Left(horaAtual,2))
    m = CInt(Right(horaAtual,2))

    dt = d + TimeSerial(h, m, 0)
    dt = DateAdd("n", minutos, dt)

    SomaMinutosComData = Right("0" & Hour(dt), 2) & Right("0" & Minute(dt), 2)
    dataTmp = Right("0" & Day(dt), 2) & Right("0" & Month(dt), 2) & Year(dt)
End Function


' ============================================================
' =================== FUNCAO APONTAR ORDEM ===================
' ============================================================

Sub ApontarOrdem(ORDEM_ATUAL, ByRef horaAtual, ByRef dataAtual)

    Dim campo

    ' === Abre IW41 via barra (substitui duplo clique) ===
    session.findById("wnd[0]/tbar[0]/okcd").Text = "/nIW41"
    session.findById("wnd[0]").sendVKey 0

    ' Aguarda campo AUFNR existir
    Do
        On Error Resume Next
        Set campo = session.findById("wnd[0]/usr/ctxtCORUF-AUFNR", False)
        On Error GoTo 0
        If Not campo Is Nothing Then Exit Do
        WScript.Sleep 200
    Loop

    ' === Igual fluxo da macro ===
    campo.SetFocus
    campo.Text = ""
    campo.Text = CStr(ORDEM_ATUAL)
    campo.CaretPosition = Len(CStr(ORDEM_ATUAL))

    session.findById("wnd[0]").sendVKey 0

    If session.findById("wnd[0]/usr/chkAFRUD-AUERU", False) Is Nothing Then
        session.findById("wnd[0]/tbar[1]/btn[13]").Press
        session.findById("wnd[0]/usr/tblSAPLCORUTC_3100/txtAFVGD-ARBPL[4,0]").SetFocus
        session.findById("wnd[0]").sendVKey 2
    End If
'MsgBox "Teste conclu do at  sele  o da tarefa."
'Exit Sub


    Dim i, horaFim
    Dim dataInicio, dataFim, dataTmp, duracaoAtual

    For i = 1 To TOTAL_TAREFAS

        dataInicio = dataAtual
        dataTmp    = dataAtual

        If MAPA_DURACAO_TAREFA.Exists(i) Then
            duracaoAtual = MAPA_DURACAO_TAREFA(i)
        Else
            duracaoAtual = DURACAO_TAREFA
        End If

        horaFim = SomaMinutosComData(dataTmp, horaAtual, duracaoAtual)
        dataFim = dataTmp

        session.findById("wnd[0]/usr/ctxtAFRUD-ARBPL").Text = CENTRO_TRAB
        session.findById("wnd[0]/usr/ctxtAFRUD-ISDD").Text = dataInicio
        session.findById("wnd[0]/usr/ctxtAFRUD-ISDZ").Text = horaAtual
        session.findById("wnd[0]/usr/ctxtAFRUD-IEDD").Text = dataFim
        session.findById("wnd[0]/usr/ctxtAFRUD-IEDZ").Text = horaFim
        session.findById("wnd[0]/usr/txtAFRUD-ISMNW_2").Text = duracaoAtual
        session.findById("wnd[0]/usr/ctxtAFRUD-ISMNU").Text = "MIN"
        session.findById("wnd[0]/usr/chkAFRUD-AUERU").Selected = True
        session.findById("wnd[0]/usr/chkAFRUD-LEKNW").Selected = True

        ' ===== TEXTO =====
        If ORDEM_ELETRICA And MAPA_TEXTO_ELETRICO.Exists(i) Then
            session.findById("wnd[0]/usr/txtAFRUD-LTXA1").Text = MAPA_TEXTO_ELETRICO(i)
        Else
            session.findById("wnd[0]/usr/txtAFRUD-LTXA1").Text = TEXTO_PADRAO
        End If

        ' ===== ENTER 1 ? dispara aviso de dia n o  til =====
        session.findById("wnd[0]").sendVKey 0

        ' ===== ENTER 2 ? confirma aviso (igual manual) =====
        session.findById("wnd[0]").sendVKey 0

        If i < TOTAL_TAREFAS Then
            session.findById("wnd[0]/tbar[1]/btn[23]").Press
        End If

        horaAtual = horaFim
        dataAtual = dataFim
    Next

    session.findById("wnd[0]/tbar[0]/btn[11]").Press
    session.findById("wnd[0]/tbar[0]/btn[15]").Press
End Sub

' ============================================================
' ===================== EXECUCAO FINAL =======================
' ============================================================

Dim horaAtual, dataAtual, ordem

horaAtual = HORA_INICIAL
dataAtual = DATA_INICIAL

' ===== ORDENS SEQUENCIAIS =====
If ORDEM_INICIAL > 0 And ORDEM_FINAL > 0 And ORDEM_INICIAL <= ORDEM_FINAL Then
    For ordem = ORDEM_INICIAL To ORDEM_FINAL
        Call ApontarOrdem(ordem, horaAtual, dataAtual)
    Next
End If

' ===== ORDENS MANUAIS =====
If IsArray(ORDENS_MANUAIS) Then
    For Each ordem In ORDENS_MANUAIS
        Call ApontarOrdem(ordem, horaAtual, dataAtual)
    Next
End If

</textarea>

</body>
</html>
